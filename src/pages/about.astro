---
import Layout from '../layouts/Layout.astro';
import about from '../data/about.json';
---

<Layout title="About" description="About me — background, skills, education, and experience.">
  <div class="max-w-3xl mx-auto px-6 py-16">

    <!-- Header + bio -->
    <div class="mb-10">
      <h1 class="text-5xl font-bold text-ink-900 mb-4 tracking-tight">About</h1>
      <p class="text-ink-500 text-lg leading-relaxed max-w-xl">{about.bio}</p>
    </div>

    <!-- Social contact -->
    <div class="flex flex-wrap gap-4 mb-14">
      {about.contact.email && (
        <a href={`mailto:${about.contact.email}`} class="inline-flex items-center gap-2 text-sm text-ink-500 hover:text-accent transition-colors">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          {about.contact.email}
        </a>
      )}
      {about.contact.linkedin && (
        <a href={about.contact.linkedin} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-ink-500 hover:text-accent transition-colors">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      )}
      {about.contact.github && (
        <a href={about.contact.github} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-sm text-ink-500 hover:text-accent transition-colors">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GitHub
        </a>
      )}
      {about.contact.tel && (
        <a href={`tel:${about.contact.tel}`} class="inline-flex items-center gap-2 text-sm text-ink-500 hover:text-accent transition-colors">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          {about.contact.tel}
        </a>
      )}
    </div>

    <!-- Skills -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-ink-900 mb-6 tracking-tight">Skills</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {about.skills.map(group => (
          <div class="bg-paper-50 border border-paper-300 rounded-lg px-4 py-3">
            <p class="text-sm font-semibold text-ink-900 mb-2">{group.category}</p>
            <div class="flex flex-wrap gap-1.5">
              {group.items.map(item => (
                <span class="skill-chip">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr class="border-paper-300 mb-14" />

    <!-- Education -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-ink-900 mb-6 tracking-tight">Education</h2>
      <div class="divide-y divide-paper-300 border-t border-paper-300">
        {about.education.map(ed => (
          <div class="py-5 flex flex-col sm:flex-row sm:gap-8">
            <div class="sm:w-44 sm:flex-shrink-0 mb-1 sm:mb-0">
              <span class="text-sm text-ink-300 whitespace-nowrap">{ed.period}</span>
            </div>
            <div>
              <p class="font-semibold text-ink-900">{ed.degree}</p>
              <p class="text-ink-500 text-sm mt-0.5">{ed.school}</p>
              {ed.detail && <p class="text-ink-500 text-sm mt-2 leading-relaxed">{ed.detail}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <hr class="border-paper-300 mb-14" />

    <!-- Experience -->
    <section>
      <h2 class="text-2xl font-bold text-ink-900 mb-6 tracking-tight">Experience</h2>
      <div class="divide-y divide-paper-300 border-t border-paper-300">
        {about.experience.map(job => (
          <div class="py-5 flex flex-col sm:flex-row sm:gap-8">
            <div class="sm:w-44 sm:flex-shrink-0 mb-1 sm:mb-0">
              <span class="text-sm text-ink-300 whitespace-nowrap">{job.period}</span>
            </div>
            <div>
              <p class="font-semibold text-ink-900">{job.title}</p>
              <p class="text-ink-500 text-sm mt-0.5">{job.company}</p>
              {job.description && <p class="text-ink-500 text-sm mt-2 leading-relaxed">{job.description}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</Layout>

<style>
  .skill-chip {
    display: inline-flex;
    align-items: center;
    padding: 1px 8px;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 500;
    background: #f5f5f4;
    border: 1px solid #e7e5e4;
    color: #374151;
  }

  html.dark .skill-chip {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.1);
    color: #94a3b8;
  }
</style>
