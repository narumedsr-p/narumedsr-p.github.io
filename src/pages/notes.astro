---
import Layout from '../layouts/Layout.astro';
import { fileURLToPath } from 'node:url';
import fs from 'node:fs';

// Resolve path relative to this file so it works in both dev and build
const filePath = fileURLToPath(new URL('../data/notes.txt', import.meta.url));
let notes: { date: string; text: string }[] = [];

if (fs.existsSync(filePath)) {
  const raw = fs.readFileSync(filePath, 'utf-8');
  notes = raw
    .split('\n')
    .map(line => line.trim())
    .filter(line => line && !line.startsWith('#'))
    .map(line => {
      const sep = line.indexOf('|');
      if (sep === -1) return { date: '', text: line };
      return { date: line.slice(0, sep).trim(), text: line.slice(sep + 1).trim() };
    })
    .reverse();
}
---

<Layout title="Notes" description="Quick thoughts, ideas, and daily notes.">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <div class="mb-10">
      <h1 class="text-5xl font-bold text-ink-900 mb-3 tracking-tight">Notes</h1>
      <p class="text-ink-500">
        Quick thoughts worth keeping.
        Append a line to <code class="text-xs bg-paper-200 px-1.5 py-0.5 rounded">src/data/notes.txt</code> and push.
      </p>
    </div>

    {notes.length > 0 ? (
      <div class="divide-y divide-paper-300 border-t border-paper-300">
        {notes.map(note => (
          <div class="py-4 flex flex-col sm:flex-row sm:gap-8 sm:items-baseline">
            {note.date && (
              <time class="text-xs text-ink-100 sm:w-28 sm:flex-shrink-0 mb-1 sm:mb-0">{note.date}</time>
            )}
            <p class="text-ink-700 text-base leading-relaxed">{note.text}</p>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-ink-300 py-10 text-center">No notes yet.</p>
    )}

    <div class="mt-14 bg-paper-200 border border-paper-300 rounded-lg p-5">
      <p class="text-xs text-ink-300 mb-2">// add a note — append to src/data/notes.txt</p>
      <pre class="text-xs text-ink-500 leading-relaxed">{`2025-06-01 | Your thought here.
2025-06-02 | Another one.`}</pre>
    </div>
  </div>
</Layout>
