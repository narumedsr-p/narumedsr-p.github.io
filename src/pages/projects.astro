---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTech = [...new Set(all.flatMap(p => p.data.tech))].sort();
---

<Layout title="Projects" description="All my projects — open source, experiments, and shipped products.">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-10">
      <h1 class="font-serif text-4xl text-ink-900 mb-3">Projects</h1>
      <p class="text-ink-500 max-w-lg">Things I've built — open source tools, experiments, and side projects.</p>
    </div>

    <!-- Tech filter -->
    <div class="flex flex-wrap gap-2 mb-8" id="filters">
      <button data-filter="all" class="filter-btn chip chip-accent cursor-pointer">All</button>
      {allTech.map(t => (
        <button data-filter={t} class="filter-btn chip cursor-pointer hover:bg-paper-200 transition-colors">{t}</button>
      ))}
    </div>

    <div class="grid sm:grid-cols-2 gap-4" id="project-grid">
      {all.map(p => (
        <article class="project-card bg-paper-50 border border-paper-300 rounded-lg p-5 hover:border-ink-100 hover:shadow-sm transition-all group" data-tech={p.data.tech.join(',')}>
          <div class="flex items-start justify-between mb-3">
            <h2 class="font-semibold text-ink-900 group-hover:text-accent transition-colors">{p.data.title}</h2>
            <div class="flex items-center gap-3 ml-3 flex-shrink-0">
              {p.data.github && (
                <a href={p.data.github} target="_blank" rel="noopener" class="text-ink-100 hover:text-ink-700 transition-colors" title="GitHub" onclick="event.stopPropagation()">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                </a>
              )}
              {p.data.demo && (
                <a href={p.data.demo} target="_blank" rel="noopener" class="text-ink-100 hover:text-ink-700 transition-colors" title="Live demo" onclick="event.stopPropagation()">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              )}
            </div>
          </div>
          <p class="text-ink-500 text-base leading-relaxed mb-4">{p.data.description}</p>
          <div class="flex flex-wrap gap-1.5 mb-3">
            {p.data.tech.map((t: string) => <span class="chip">{t}</span>)}
          </div>
          <a href={`/projects/${p.slug}`} class="text-xs text-accent hover:underline underline-offset-4">Details →</a>
        </article>
      ))}
    </div>

    {all.length === 0 && (
      <div class="text-center py-20 text-ink-100">
        <p class="mb-3 text-lg">No projects yet.</p>
        <p class="text-sm">Add a <code class="font-mono text-xs bg-paper-200 px-2 py-0.5 rounded">.md</code> file to <code class="font-mono text-xs bg-paper-200 px-2 py-0.5 rounded">src/content/projects/</code></p>
      </div>
    )}
  </div>
</Layout>

<script>
  const btns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card') as NodeListOf<HTMLElement>;

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => { b.classList.remove('chip-accent'); b.classList.add('chip'); });
      btn.classList.add('chip-accent');
      const f = btn.getAttribute('data-filter');
      cards.forEach(c => {
        c.style.display = (f === 'all' || (c.getAttribute('data-tech') || '').includes(f!)) ? '' : 'none';
      });
    });
  });
</script>
